# 留空也能运行：系统会自动进入 Demo Mode

# ===== Supabase（可选） =====
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== AI（可选） =====
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ===== 讯飞 Spark X API（推荐） =====
# 申请地址：https://www.xfyun.cn/doc/spark/X1http.html
XFYUN_BASE_URL=https://spark-api-open.xf-yun.com/x2/chat/completions
XFYUN_MODEL=spark-x
XFYUN_APPID=
XFYUN_API_SECRET=
XFYUN_API_KEY=
# 如果控制台提供了 APIPassword，也可以直接配置它；否则系统会使用 APIKey:APISecret。
XFYUN_API_PASSWORD=

# ===== 强制演示模式（可选） =====
FORCE_DEMO_MODE=0
NEXT_PUBLIC_FORCE_DEMO_MODE=0
